{% # theme-check-disable %}
{%- comment -%}
  Preload self-hosted fonts to prevent FOUT (Flash of Unstyled Text).
  Update this list when custom theme fonts are added or updated in the assets folder.
{%- endcomment -%}
{%- liquid
  assign fonts_to_preload = 'albert-sans-latin.woff2,sen-latin.woff2' | split: ','
-%}

{%- for font_file in fonts_to_preload -%}
  <link
    rel="preload"
    as="font"
    href="{{ font_file | asset_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="high"
  >
{%- endfor -%}
{% # theme-check-enable %}
